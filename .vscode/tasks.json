{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Iniciar servidor web",
            "type": "shell",
            "command": "python -m http.server 8080",
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": { "regexp": "^$" },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            }
        },
        {
            "label": "Abrir index.html",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "start", "", "${workspaceFolder}/index.html"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
